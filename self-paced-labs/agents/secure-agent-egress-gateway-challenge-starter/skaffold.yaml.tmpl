apiVersion: skaffold/v4beta13
kind: Config
metadata:
  name: legacy-dms

build:
  tagPolicy:
    inputDigest: {}
  artifacts:
    - image: ${REGION}-docker.pkg.dev/${PROJECT_ID}/gateway-docker/legacy-dms
      context: src/legacy-dms
      docker:
        dockerfile: Dockerfile
  googleCloudBuild:
    projectId: ${PROJECT_ID}
    region: ${REGION}

manifests:
  rawYaml:
    - cloudrun/legacy-dms.yaml

deploy:
  cloudrun:
    projectid: ${PROJECT_ID}
    region: ${REGION}

